<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Creates one log file per LLM component, discriminated by MDC key 'llm_component' -->
    <appender name="LLM_SIFT" class="ch.qos.logback.classic.sift.SiftingAppender">
        <discriminator>
            <key>llm_component</key>
            <defaultValue>unknown</defaultValue>
        </discriminator>
        <sift>
            <appender name="LLM_FILE_${llm_component}" class="ch.qos.logback.core.FileAppender">
                <file>log/llm/${llm_component}.log</file>
                <append>true</append>
                <encoder>
                    <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level - %msg%n</pattern>
                </encoder>
            </appender>
        </sift>
    </appender>

    <!-- llm.* loggers go exclusively to their per-component file -->
    <logger name="llm" level="INFO" additivity="false">
        <appender-ref ref="LLM_SIFT"/>
    </logger>

    <!-- Root logger keeps logging everything else to console as normal -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>