<configuration>

    <!-- Keep the default console appender behaviour -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Dedicated file appender for LLM tool output -->
    <appender name="LLM_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/llm-output.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/llm-output.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Route this specific class to the dedicated file only -->
    <logger name="com.czintercity.icsec_app.ai.tools"
            level="INFO"
            additivity="true">
        <appender-ref ref="LLM_FILE"/>
    </logger>

    <!-- Root logger keeps logging everything else to console as normal -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>